# K6 Testing Configuration
# Copy this file to .env and fill in your values

# Base URL for the site under test
BASE_URL=https://preludeelectronics.com

# Test execution configuration
# Smoke Test: Minimal load, quick validation
SMOKE_VUS=2
SMOKE_DURATION=30s

# Load Test: Normal operational load
LOAD_VUS=10
LOAD_DURATION=5m

# Stress Test: High load to find breaking point
STRESS_VUS=50
STRESS_DURATION=10m

# Spike Test: Sudden load spike
SPIKE_VUS=100
SPIKE_DURATION=2m

# Thresholds and tolerances
# Maximum allowed response time in ms
RESPONSE_TIME_THRESHOLD=3000

# Maximum allowed error rate (0-1)
ERROR_RATE_THRESHOLD=0.01

# Notification settings
# Set to 'true' to enable notifications
ENABLE_NOTIFICATIONS=false

# Logging
LOG_LEVEL=info
