{
  "name": "prelude-electronics-e2e",
  "version": "1.0.0",
  "description": "End-to-end tests for preludeelectronics.com — Playwright + TypeScript + Page Object Model",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:report": "playwright show-report",
    "codegen": "playwright codegen https://preludeelectronics.com",
    "allure:generate": "node scripts/preserve-allure-history.js && allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:run": "npm test && npm run allure:generate && npm run allure:open"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "typescript",
    "pom",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "dotenv": "^16.6.1"
  }
}
