{
  "name": "prelude-electronics-e2e",
  "version": "1.0.0",
  "description": "End-to-end tests for preludeelectronics.com — Playwright + TypeScript + Page Object Model",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:report": "playwright show-report",
    "codegen": "playwright codegen https://preludeelectronics.com",
    "allure:generate": "node scripts/preserve-allure-history.js && allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:run": "npm test && npm run allure:generate && npm run allure:open",
    "wdio:test": "wdio run ./wdio/wdio.android.conf.js",
    "wdio:test:debug": "wdio run ./wdio/wdio.android.conf.js --logLevel debug",
    "wdio:boot-and-test": "powershell -ExecutionPolicy Bypass -File scripts/run-wdio-mobile.ps1",
    "wdio:boot-and-test:unix": "bash scripts/run-wdio-mobile.sh",
    "appium:driver:install": "appium driver install uiautomator2",
    "appium:driver:doctor": "appium driver doctor uiautomator2"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "typescript",
    "pom",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "@wdio/appium-service": "^9.27.1",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "appium": "^3.3.1",
    "appium-uiautomator2-driver": "^7.1.2",
    "dotenv": "^16.6.1",
    "expect-webdriverio": "^5.6.5",
    "webdriverio": "^9.27.1"
  }
}
